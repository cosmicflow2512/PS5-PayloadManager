<Window x:Class="PS5AutoPayloadTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PS5AutoPayloadTool.Views"
        Title="PS5 AutoPayload Tool"
        Icon="Assets/icon.ico"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- Sidebar -->
    <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="20,24,20,20">
          <TextBlock Text="PS5 AutoPayload" Foreground="{StaticResource Accent}" FontSize="18" FontWeight="Bold"/>
          <TextBlock Text="Tool v1.1" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Nav items -->
        <StackPanel Grid.Row="1" Margin="10,0">
          <RadioButton x:Name="NavSources"  Style="{StaticResource NavButton}" GroupName="Nav" IsChecked="True"
                       Content="&#xE710;  Sources" FontFamily="Segoe MDL2 Assets,Segoe UI"
                       Click="Nav_Click" Tag="Sources"/>
          <RadioButton x:Name="NavPayloads" Style="{StaticResource NavButton}" GroupName="Nav"
                       Content="&#xE8A9;  Payloads" FontFamily="Segoe MDL2 Assets,Segoe UI"
                       Click="Nav_Click" Tag="Payloads"/>
          <RadioButton x:Name="NavBuilder"  Style="{StaticResource NavButton}" GroupName="Nav"
                       Content="&#xE768;  Autoload Builder" FontFamily="Segoe MDL2 Assets,Segoe UI"
                       Click="Nav_Click" Tag="Builder"/>
          <RadioButton x:Name="NavProfiles" Style="{StaticResource NavButton}" GroupName="Nav"
                       Content="&#xE8FD;  Profiles" FontFamily="Segoe MDL2 Assets,Segoe UI"
                       Click="Nav_Click" Tag="Profiles"/>
          <RadioButton x:Name="NavSettings" Style="{StaticResource NavButton}" GroupName="Nav"
                       Content="&#xE713;  Settings" FontFamily="Segoe MDL2 Assets,Segoe UI"
                       Click="Nav_Click" Tag="Settings"/>
          <RadioButton x:Name="NavLogs"     Style="{StaticResource NavButton}" GroupName="Nav"
                       Content="&#xE9D9;  Logs" FontFamily="Segoe MDL2 Assets,Segoe UI"
                       Click="Nav_Click" Tag="Logs"/>
        </StackPanel>

        <!-- Connection status (bottom) -->
        <Border Grid.Row="2" Padding="20,16" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
          <StackPanel>
            <TextBlock x:Name="DeviceNameText" Text="No device" Foreground="{StaticResource Accent}" FontWeight="SemiBold" FontSize="13"/>
            <TextBlock x:Name="DeviceIpText"   Text="Set IP in Settings"  Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <!-- Content area -->
    <ContentControl x:Name="ContentHost" Grid.Column="1"/>
  </Grid>
</Window>
