<Window x:Class="PS5AutoPayloadTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PS5 AutoPayload Tool"
        Height="680" Width="960"
        MinHeight="520" MinWidth="780"
        Background="#1E1E2E"
        Foreground="#CDD6F4"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- ── Colours ──────────────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgBase"     Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgMantle"   Color="#181825"/>
        <SolidColorBrush x:Key="BgSurface"  Color="#313244"/>
        <SolidColorBrush x:Key="BgOverlay"  Color="#45475A"/>
        <SolidColorBrush x:Key="FgMain"     Color="#CDD6F4"/>
        <SolidColorBrush x:Key="FgSubtle"   Color="#6C7086"/>
        <SolidColorBrush x:Key="Accent"     Color="#89B4FA"/>
        <SolidColorBrush x:Key="Green"      Color="#A6E3A1"/>
        <SolidColorBrush x:Key="Red"        Color="#F38BA8"/>
        <SolidColorBrush x:Key="Yellow"     Color="#F9E2AF"/>
        <SolidColorBrush x:Key="BorderClr"  Color="#45475A"/>

        <!-- ── Button base ───────────────────────────────────────────────────── -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Foreground"       Value="{StaticResource FgMain}"/>
            <Setter Property="Background"       Value="{StaticResource BgSurface}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderClr}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,5"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BgOverlay}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#1C6BBE"/>
            <Setter Property="Foreground" Value="#EFF1F5"/>
            <Setter Property="BorderBrush" Value="#89B4FA"/>
        </Style>

        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2D6A4A"/>
            <Setter Property="Foreground" Value="#A6E3A1"/>
            <Setter Property="BorderBrush" Value="#A6E3A1"/>
        </Style>

        <Style x:Key="BtnRed" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#6B2D3A"/>
            <Setter Property="Foreground" Value="#F38BA8"/>
            <Setter Property="BorderBrush" Value="#F38BA8"/>
        </Style>

        <Style x:Key="BtnYellow" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#5C4C1E"/>
            <Setter Property="Foreground" Value="#F9E2AF"/>
            <Setter Property="BorderBrush" Value="#F9E2AF"/>
        </Style>

        <!-- ── TextBox ───────────────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"    Value="{StaticResource BgMantle}"/>
            <Setter Property="Foreground"    Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BorderClr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush"    Value="{StaticResource FgMain}"/>
            <Setter Property="Padding"       Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── ListBox ───────────────────────────────────────────────────────── -->
        <Style TargetType="ListBox">
            <Setter Property="Background"    Value="{StaticResource BgMantle}"/>
            <Setter Property="Foreground"    Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BorderClr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
            <Setter Property="Padding"    Value="7,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#282838"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── GroupBox ──────────────────────────────────────────────────────── -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"    Value="{StaticResource FgSubtle}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BorderClr}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="6"/>
        </Style>

        <!-- ── CheckBox ──────────────────────────────────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"    Value="{StaticResource FgMain}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Separator ─────────────────────────────────────────────────────── -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BorderClr}"/>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- header -->
            <RowDefinition Height="Auto"/>   <!-- connection bar -->
            <RowDefinition Height="*"/>      <!-- main content -->
            <RowDefinition Height="Auto"/>   <!-- status / controls -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════ HEADER ══════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="PS5" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Accent}"/>
            <TextBlock Text=" AutoPayload " FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource FgMain}"/>
            <TextBlock Text="Tool" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Green}"/>
            <TextBlock Text=" v1.0" FontSize="12"
                       Foreground="{StaticResource FgSubtle}"
                       VerticalAlignment="Bottom" Margin="4,0,0,3"/>
        </StackPanel>

        <!-- ═════════════════════════ CONNECTION BAR ═════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource BgMantle}"
                BorderBrush="{StaticResource BorderClr}"
                BorderThickness="1" CornerRadius="5"
                Padding="10,7" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- IP label + input -->
                <TextBlock Grid.Column="0" Text="PS5 IP:"
                           Foreground="{StaticResource FgSubtle}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="1" x:Name="TxtHost"
                         Text="192.168.1.100" Height="28"/>

                <!-- Port status indicators -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0">
                    <Ellipse x:Name="EllipseLua" Width="9" Height="9"
                             Fill="{StaticResource BgOverlay}" Margin="0,0,5,0"/>
                    <TextBlock Text="Lua 9026" Foreground="{StaticResource FgSubtle}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Ellipse x:Name="EllipseElf" Width="9" Height="9"
                             Fill="{StaticResource BgOverlay}" Margin="0,0,5,0"/>
                    <TextBlock Text="ELF 9021" Foreground="{StaticResource FgSubtle}"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Auto-send -->
                <CheckBox Grid.Column="4" x:Name="ChkAutoSend"
                          Content="Auto-Send" Margin="10,0"
                          Checked="ChkAutoSend_Checked"
                          Unchecked="ChkAutoSend_Unchecked"/>

                <!-- Buttons -->
                <Button Grid.Column="5" Content="Check Ports"
                        Style="{StaticResource Btn}" Margin="4,0"
                        Click="BtnCheckPorts_Click"/>
                <Button Grid.Column="6" Content="Open Data Folder"
                        Style="{StaticResource Btn}" Margin="4,0"
                        Click="BtnOpenDataFolder_Click"/>
                <Button Grid.Column="7" Content="Clear Log"
                        Style="{StaticResource Btn}"
                        Click="BtnClearLog_Click"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════ MAIN AREA ════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT PANEL ─────────────────────────────────────────────── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- Payloads -->
                <GroupBox Grid.Row="0" Header="Payloads (.lua / .elf / .bin)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox Grid.Row="0" x:Name="LstPayloads"
                                 AllowDrop="True"
                                 Drop="LstPayloads_Drop"
                                 DragOver="LstPayloads_DragOver"
                                 FontFamily="Consolas" FontSize="12"
                                 ToolTip="Drag &amp; drop payload files here"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Add…" Style="{StaticResource Btn}"
                                    Click="BtnAddPayload_Click" Padding="10,4" Margin="0,0,3,0"/>
                            <Button Content="Remove" Style="{StaticResource Btn}"
                                    Click="BtnRemovePayload_Click" Padding="10,4" Margin="0,0,3,0"/>
                            <Button x:Name="BtnSend" Content="Send"
                                    Style="{StaticResource BtnAccent}"
                                    Click="BtnSendPayload_Click" Padding="14,4"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- Profiles -->
                <GroupBox Grid.Row="2" Header="Profiles (.txt)">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox Grid.Row="0" x:Name="LstProfiles"
                                 FontFamily="Consolas" FontSize="12"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Load…" Style="{StaticResource Btn}"
                                    Click="BtnLoadProfile_Click" Padding="10,4" Margin="0,0,3,0"/>
                            <Button x:Name="BtnRun" Content="Run Profile"
                                    Style="{StaticResource BtnGreen}"
                                    Click="BtnRunProfile_Click" Padding="10,4"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="6"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BgSurface}"/>

            <!-- ── LOG PANEL ──────────────────────────────────────────────── -->
            <GroupBox Grid.Column="2" Header="Log">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" x:Name="LstLog"
                             FontFamily="Consolas" FontSize="12"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingStackPanel.IsVirtualizing="True"/>

                    <ProgressBar Grid.Row="1" x:Name="PrgProgress"
                                 Height="6" Margin="0,6,0,0"
                                 Minimum="0" Maximum="100" Value="0"
                                 Background="{StaticResource BgSurface}"
                                 Foreground="{StaticResource Accent}"
                                 BorderThickness="0"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- ═══════════════════════ STATUS + CONTROLS ════════════════════════ -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Status bar -->
            <Border Background="{StaticResource BgMantle}"
                    BorderBrush="{StaticResource BorderClr}"
                    BorderThickness="1" CornerRadius="4"
                    Padding="8,4" VerticalAlignment="Center">
                <TextBlock x:Name="TxtStatus" Text="Ready"
                           Foreground="{StaticResource FgSubtle}"
                           FontSize="11" FontFamily="Consolas"/>
            </Border>

            <!-- Control buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                <Button x:Name="BtnPause" Content="Pause"
                        Style="{StaticResource BtnYellow}"
                        Width="76" Margin="0,0,5,0"
                        IsEnabled="False"
                        Click="BtnPause_Click"/>
                <Button x:Name="BtnStop" Content="Stop"
                        Style="{StaticResource BtnRed}"
                        Width="76"
                        IsEnabled="False"
                        Click="BtnStop_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
