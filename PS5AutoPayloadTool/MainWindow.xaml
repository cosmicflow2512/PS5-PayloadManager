<Window x:Class="PS5AutoPayloadTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PS5 AutoPayload Tool"
        Height="700" Width="1050"
        MinHeight="520" MinWidth="800"
        Background="{StaticResource BgBase}"
        Foreground="{StaticResource FgMain}"
        WindowStartupLocation="CenterScreen">

    <!-- Resources MUST appear before any content that references them -->
    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="RadioButton">
            <Setter Property="Foreground"                 Value="{StaticResource FgSubtle}"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="FontSize"                   Value="13"/>
            <Setter Property="Padding"                    Value="16,11"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A5F"/>
                                <Setter Property="Foreground"                 Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgSurface}"/>
                                <Setter Property="Foreground"                 Value="{StaticResource FgMain}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═════════════════════════ SIDEBAR ════════════════════════════ -->
        <Grid Grid.Column="0" Background="{StaticResource BgMantle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App Title -->
            <StackPanel Grid.Row="0" Margin="16,18,16,14">
                <TextBlock Text="PS5 AutoPayload"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource Accent}"/>
                <TextBlock Text="Tool v1.0"
                           FontSize="10"
                           Foreground="{StaticResource FgSubtle}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <Separator Grid.Row="1" Background="{StaticResource BgSurface}" Margin="0"/>

            <!-- Nav Items -->
            <StackPanel Grid.Row="2" Margin="0,8,0,0">
                <RadioButton x:Name="NavSources"
                             Content="&#x2295;  Sources"
                             GroupName="Nav" IsChecked="True"
                             Checked="NavSources_Checked"
                             Style="{StaticResource NavBtn}"/>
                <RadioButton x:Name="NavPayloads"
                             Content="&#x229E;  Payloads"
                             GroupName="Nav"
                             Checked="NavPayloads_Checked"
                             Style="{StaticResource NavBtn}"/>
                <RadioButton x:Name="NavFlow"
                             Content="&#x25B6;  Flow Builder"
                             GroupName="Nav"
                             Checked="NavFlow_Checked"
                             Style="{StaticResource NavBtn}"/>
                <RadioButton x:Name="NavProfiles"
                             Content="&#x2261;  Profiles"
                             GroupName="Nav"
                             Checked="NavProfiles_Checked"
                             Style="{StaticResource NavBtn}"/>
                <RadioButton x:Name="NavSettings"
                             Content="&#x2699;  Settings"
                             GroupName="Nav"
                             Checked="NavSettings_Checked"
                             Style="{StaticResource NavBtn}"/>
            </StackPanel>

            <!-- Sidebar Footer: PS5 IP + port dots -->
            <Border Grid.Row="3" Background="{StaticResource BgBase}" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="PS5 Console"
                               FontSize="10"
                               Foreground="{StaticResource FgSubtle}"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="SidebarHost"
                               Text="192.168.1.100"
                               FontSize="11"
                               Foreground="{StaticResource FgMain}"
                               Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="SidebarLuaDot"
                                 Width="7" Height="7"
                                 Fill="{StaticResource BgOverlay}"
                                 Margin="0,0,4,0"/>
                        <TextBlock Text="Lua"
                                   FontSize="10"
                                   Foreground="{StaticResource FgSubtle}"
                                   Margin="0,0,10,0"/>
                        <Ellipse x:Name="SidebarElfDot"
                                 Width="7" Height="7"
                                 Fill="{StaticResource BgOverlay}"
                                 Margin="0,0,4,0"/>
                        <TextBlock Text="ELF"
                                   FontSize="10"
                                   Foreground="{StaticResource FgSubtle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════ CONTENT AREA ══════════════════════════ -->
        <ContentControl Grid.Column="1"
                        x:Name="ContentArea"
                        Background="{StaticResource BgBase}"/>
    </Grid>

</Window>
