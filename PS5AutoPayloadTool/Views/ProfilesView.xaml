<UserControl x:Class="PS5AutoPayloadTool.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrimary}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Saved Flows" Foreground="{StaticResource TextPrimary}"
               FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20"/>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <ItemsControl x:Name="ProfilesList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimary}"
                             FontWeight="SemiBold" FontSize="14"/>
                  <TextBlock Text="{Binding Info}" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                  <Button Content="Edit"   Style="{StaticResource BtnSecondary}" Click="OnEdit"   Tag="{Binding Filename}" Margin="0,0,4,0"/>
                  <Button Content="Run"    Style="{StaticResource BtnPrimary}"   Click="OnRun"    Tag="{Binding Filename}" Margin="0,0,4,0"/>
                  <Button Content="Delete" Style="{StaticResource BtnDanger}"    Click="OnDelete" Tag="{Binding Filename}"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
