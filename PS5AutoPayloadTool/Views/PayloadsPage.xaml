<UserControl x:Class="PS5AutoPayloadTool.Views.PayloadsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,20">

                <!-- ── Header ─────────────────────────────────────────── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Payloads"
                               Style="{StaticResource PageTitle}"
                               VerticalAlignment="Center"
                               Margin="0"/>
                    <Button Grid.Column="1"
                            Content="Check All Updates"
                            Style="{StaticResource BtnAccent}"
                            Click="BtnCheckAll_Click"/>
                </Grid>

                <!-- ── Status ─────────────────────────────────────────── -->
                <TextBlock x:Name="TxtStatus"
                           Text=""
                           Foreground="{StaticResource FgSubtle}"
                           FontSize="12"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"/>

                <!-- ── Download progress ──────────────────────────────── -->
                <ProgressBar x:Name="PrgDownload"
                             Minimum="0" Maximum="100"
                             Value="0"
                             Visibility="Collapsed"
                             Margin="0,0,0,10"/>

                <!-- ── Payloads list ──────────────────────────────────── -->
                <ItemsControl x:Name="PayloadsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Left: info -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Downloaded indicator dot -->
                                            <Ellipse Width="8" Height="8"
                                                     Margin="0,0,8,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource BgOverlay}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource Green}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FgMain}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Meta.SourceUrl}"
                                                   Foreground="{StaticResource FgSubtle}"
                                                   FontSize="11" Margin="16,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <StackPanel Orientation="Horizontal" Margin="16,6,0,0">
                                            <TextBlock Text="Version:"
                                                       Foreground="{StaticResource FgSubtle}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <ComboBox ItemsSource="{Binding AvailableVersions}"
                                                      SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                                                      Width="130"
                                                      FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right: buttons -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Download"
                                                Style="{StaticResource BtnAccent}"
                                                Padding="10,4"
                                                Margin="0,0,6,0"
                                                Tag="{Binding Id}"
                                                Click="BtnDownload_Click"/>
                                        <Button Content="Delete"
                                                Style="{StaticResource BtnDanger}"
                                                Padding="10,4"
                                                Tag="{Binding Id}"
                                                Click="BtnDeletePayload_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── Empty state ────────────────────────────────────── -->
                <Border x:Name="EmptyState"
                        Style="{StaticResource Card}"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="No payloads found"
                                   Foreground="{StaticResource FgSubtle}"
                                   HorizontalAlignment="Center"
                                   FontSize="14"/>
                        <TextBlock Text="Add a source on the Sources page and scan it to discover payloads."
                                   Foreground="{StaticResource FgSubtle}"
                                   HorizontalAlignment="Center"
                                   FontSize="12" Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
