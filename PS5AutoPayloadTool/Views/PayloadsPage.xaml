<UserControl x:Class="PS5AutoPayloadTool.Views.PayloadsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,20">

                <!-- ── Header ─────────────────────────────────────────── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Payloads"
                               Style="{StaticResource PageTitle}"
                               VerticalAlignment="Center" Margin="0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="+ Add Payload"
                                Style="{StaticResource Btn}"
                                Margin="0,0,8,0"
                                Click="BtnAddPayload_Click"/>
                        <Button Content="Check Updates"
                                Style="{StaticResource BtnAccent}"
                                Margin="0,0,8,0"
                                Click="BtnCheckAll_Click"/>
                        <Button Content="Update All"
                                Style="{StaticResource BtnGreen}"
                                Click="BtnUpdateAll_Click"/>
                    </StackPanel>
                </Grid>

                <!-- ── Status ─────────────────────────────────────────── -->
                <TextBlock x:Name="TxtStatus"
                           Text="" Foreground="{StaticResource FgSubtle}"
                           FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap"/>

                <!-- ── Progress ──────────────────────────────────────── -->
                <ProgressBar x:Name="PrgDownload"
                             Minimum="0" Maximum="100" Value="0"
                             Visibility="Collapsed" Margin="0,0,0,10"/>

                <!-- ── Payloads list ──────────────────────────────────── -->
                <ItemsControl x:Name="PayloadsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <!-- ── Main row (all inline) ─────────────── -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                        <!-- Status dot -->
                                        <Ellipse Width="8" Height="8"
                                                 Margin="0,0,10,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource BgOverlay}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource Green}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource Yellow}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SourceNotAvailable}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource FgSubtle}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <!-- Filename -->
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FgMain}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>

                                        <!-- Current: vX.XX (Status) -->
                                        <TextBlock Text="Current: "
                                                   Foreground="{StaticResource FgSubtle}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CurrentVersionDisplay}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Green}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource Yellow}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SourceNotAvailable}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource FgSubtle}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Version dropdown -->
                                        <ComboBox ItemsSource="{Binding AvailableVersions}"
                                                  SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                                                  Width="120" FontSize="11"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,6,0"/>

                                        <!-- Download -->
                                        <Button Content="Download"
                                                Style="{StaticResource BtnAccent}"
                                                IsEnabled="{Binding IsDownloadEnabled}"
                                                Padding="10,4" Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                Click="BtnDownload_Click"/>

                                        <!-- Delete -->
                                        <Button Content="Delete"
                                                Style="{StaticResource BtnDanger}"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                Click="BtnDeletePayload_Click"/>
                                    </StackPanel>

                                    <!-- ── Status text (progress / error) ────── -->
                                    <TextBlock Text="{Binding StatusText}"
                                               Foreground="{StaticResource FgSubtle}"
                                               FontSize="11" Margin="18,4,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasStatus}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── Empty state ────────────────────────────────────── -->
                <Border x:Name="EmptyState"
                        Style="{StaticResource Card}"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="No payloads found"
                                   Foreground="{StaticResource FgSubtle}"
                                   HorizontalAlignment="Center" FontSize="14"/>
                        <TextBlock Text="Add a source and scan it, or click '+ Add Payload' to upload a local file."
                                   Foreground="{StaticResource FgSubtle}"
                                   HorizontalAlignment="Center"
                                   FontSize="12" Margin="0,6,0,0"
                                   TextWrapping="Wrap" MaxWidth="420"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
