<UserControl x:Class="PS5AutoPayloadTool.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrimary}">
  <ScrollViewer>
    <StackPanel Margin="24">
      <TextBlock Text="Settings" Foreground="{StaticResource TextPrimary}"
                 FontSize="22" FontWeight="SemiBold" Margin="0,0,0,24"/>

      <!-- Connection section -->
      <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Connection" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,0,16"/>
          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
              <TextBlock Text="PS4/PS5 IP Address" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
              <TextBox x:Name="IpInput" TextChanged="OnIpChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
              <TextBlock Text="GitHub Token (optional)" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
              <TextBox x:Name="TokenInput" TextChanged="OnTokenChanged"/>
            </StackPanel>
          </Grid>
          <StackPanel Orientation="Horizontal">
            <Button Content="Check Port 9021" Style="{StaticResource BtnSecondary}" Click="OnCheckPort" Margin="0,0,8,0"/>
            <Button Content="Check Port 9026" Style="{StaticResource BtnSecondary}" Click="OnCheckLua"/>
          </StackPanel>
          <TextBlock x:Name="PortStatus" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>
        </StackPanel>
      </Border>

      <!-- Devices section -->
      <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Devices" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,0,16"/>
          <ItemsControl x:Name="DevicesList" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextPrimary}"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Use"    Style="{StaticResource BtnSecondary}" Click="OnUseDevice"    Tag="{Binding Ip}" Margin="0,0,4,0" Padding="10,4"/>
                    <Button Content="Delete" Style="{StaticResource BtnDanger}"    Click="OnDeleteDevice" Tag="{Binding Id}" Padding="10,4"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="NewDeviceName" Grid.Column="0" Margin="0,0,6,0"/>
            <TextBox x:Name="NewDeviceIp"   Grid.Column="1" Margin="0,0,6,0"/>
            <Button Content="Add Device" Grid.Column="2" Style="{StaticResource BtnPrimary}" Click="OnAddDevice"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Backup section -->
      <Border Background="{StaticResource BgCard}" CornerRadius="8" Padding="20" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Backup &amp; Restore" Foreground="{StaticResource Accent}" FontWeight="SemiBold" Margin="0,0,0,16"/>
          <StackPanel Orientation="Horizontal">
            <Button Content="Export Config" Style="{StaticResource BtnSecondary}" Click="OnExport" Margin="0,0,8,0"/>
            <Button Content="Import Config" Style="{StaticResource BtnSecondary}" Click="OnImport" Margin="0,0,8,0"/>
            <Button Content="Factory Reset" Style="{StaticResource BtnDanger}"    Click="OnReset"/>
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
