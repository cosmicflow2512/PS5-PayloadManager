<UserControl x:Class="PS5AutoPayloadTool.Views.ProfilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,10">

                <!-- ── Header ─────────────────────────────────────────── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Profiles"
                               Style="{StaticResource PageTitle}"
                               VerticalAlignment="Center"
                               Margin="0"/>
                    <Button Grid.Column="1"
                            Content="Import Profile"
                            Style="{StaticResource BtnAccent}"
                            Click="BtnImport_Click"/>
                </Grid>

                <!-- ── Profile cards ──────────────────────────────────── -->
                <ItemsControl x:Name="ProfilesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FgMain}"
                                                   FontSize="13"/>
                                        <TextBlock Text="{Binding Preview}"
                                                   Foreground="{StaticResource FgSubtle}"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Content="Run"
                                                Style="{StaticResource BtnGreen}"
                                                Padding="10,4"
                                                Margin="0,0,6,0"
                                                Tag="{Binding FullPath}"
                                                Click="BtnRunProfile_Click"/>
                                        <Button Content="Edit"
                                                Style="{StaticResource Btn}"
                                                Padding="10,4"
                                                Margin="0,0,6,0"
                                                Tag="{Binding FullPath}"
                                                Click="BtnEditProfile_Click"/>
                                        <Button Content="Delete"
                                                Style="{StaticResource BtnDanger}"
                                                Padding="10,4"
                                                Tag="{Binding FullPath}"
                                                Click="BtnDeleteProfile_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── Empty state ────────────────────────────────────── -->
                <Border x:Name="EmptyState"
                        Style="{StaticResource Card}"
                        Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock Text="No profiles found"
                                   Foreground="{StaticResource FgSubtle}"
                                   HorizontalAlignment="Center"
                                   FontSize="14"/>
                        <TextBlock Text="Import a .txt profile or save a flow from the Flow Builder page."
                                   Foreground="{StaticResource FgSubtle}"
                                   HorizontalAlignment="Center"
                                   FontSize="12" Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Log + Controls at bottom ─────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource BgMantle}"
                BorderBrush="{StaticResource BgSurface}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <!-- Controls row -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <Button x:Name="BtnPause"
                            Content="Pause"
                            Style="{StaticResource BtnYellow}"
                            IsEnabled="False"
                            Margin="0,0,8,0"
                            Click="BtnPause_Click"/>
                    <Button x:Name="BtnStop"
                            Content="Stop"
                            Style="{StaticResource BtnRed}"
                            IsEnabled="False"
                            Click="BtnStop_Click"/>
                </StackPanel>

                <!-- Progress bar -->
                <ProgressBar Grid.Row="1"
                             x:Name="PrgProgress"
                             Minimum="0" Maximum="100"
                             Value="0"
                             Margin="0,0,0,6"/>

                <!-- Log -->
                <ListBox Grid.Row="2"
                         x:Name="LstLog"
                         FontFamily="Consolas"
                         FontSize="11"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>

    </Grid>

</UserControl>
