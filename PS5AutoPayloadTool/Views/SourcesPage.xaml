<UserControl x:Class="PS5AutoPayloadTool.Views.SourcesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,20">

            <!-- ── Page Header ──────────────────────────────────────────── -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Payload Sources"
                           Style="{StaticResource PageTitle}"
                           VerticalAlignment="Center" Margin="0"/>
                <Button Grid.Column="1"
                        x:Name="BtnToggleAdd"
                        Content="+ Add Source"
                        Style="{StaticResource BtnAccent}"
                        Click="BtnToggleAdd_Click"/>
            </Grid>

            <!-- ═══ STEP 1: URL + Scan ═══════════════════════════════════ -->
            <Border x:Name="ScanPanel"
                    Visibility="Collapsed"
                    Style="{StaticResource Card}"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock x:Name="FormTitle"
                               Text="Add New Source"
                               Style="{StaticResource SectionTitle}"/>

                    <TextBlock Text="Repository  (owner/repo  or  https://github.com/owner/repo)"
                               Foreground="{StaticResource FgSubtle}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtRepoUrl" FontFamily="Consolas" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnScanRepo"
                                Content="Scan Repository"
                                Style="{StaticResource BtnAccent}"
                                Margin="0,0,8,0"
                                Click="BtnScanRepo_Click"/>
                        <Button Content="Cancel"
                                Style="{StaticResource Btn}"
                                Click="BtnCancelAdd_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ STEP 2: Select mode + folder ═════════════════════════ -->
            <Border x:Name="SelectPanel"
                    Visibility="Collapsed"
                    Style="{StaticResource Card}"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock x:Name="ScanResultTitle"
                               Text="Scan Results"
                               Style="{StaticResource SectionTitle}"/>

                    <!-- Mode selection -->
                    <TextBlock Text="Source mode"
                               Foreground="{StaticResource FgSubtle}"
                               FontSize="11" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton x:Name="RbReleases"
                                     Content="GitHub Releases"
                                     Foreground="{StaticResource FgMain}"
                                     Margin="0,0,20,0"
                                     Checked="RbMode_Checked"/>
                        <RadioButton x:Name="RbFolder"
                                     Content="GitHub Folder"
                                     Foreground="{StaticResource FgMain}"
                                     Checked="RbMode_Checked"/>
                    </StackPanel>

                    <!-- Releases info (shown when Releases selected) -->
                    <TextBlock x:Name="TxtReleasesInfo"
                               Foreground="{StaticResource Green}"
                               FontSize="11" Margin="0,0,0,10"
                               Visibility="Collapsed"/>

                    <!-- No releases warning -->
                    <TextBlock x:Name="TxtNoReleasesWarn"
                               Text="No payload releases found in this repository."
                               Foreground="{StaticResource Yellow}"
                               FontSize="11" Margin="0,0,0,10"
                               Visibility="Collapsed"/>

                    <!-- Folder selection (shown when Folder selected) -->
                    <StackPanel x:Name="FolderSelectPanel" Visibility="Collapsed">
                        <TextBlock Text="Folder"
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbFolder"
                                  SelectionChanged="CmbFolder_SelectionChanged"
                                  Margin="0,0,0,8"/>
                        <StackPanel x:Name="CustomFolderPanel" Visibility="Collapsed">
                            <TextBlock Text="Custom folder path"
                                       Foreground="{StaticResource FgSubtle}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtCustomFolder"
                                     FontFamily="Consolas"
                                     Margin="0,0,0,8"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Filter (always shown) -->
                    <TextBlock Text="File filter  (optional, e.g. *.elf)"
                               Foreground="{StaticResource FgSubtle}"
                               FontSize="11" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtFilter" Margin="0,0,0,12"/>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnSaveSource"
                                Content="Save Source"
                                Style="{StaticResource BtnAccent}"
                                Margin="0,0,8,0"
                                Click="BtnSaveSource_Click"/>
                        <Button Content="Back"
                                Style="{StaticResource Btn}"
                                Click="BtnBackToScan_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Status ──────────────────────────────────────────────── -->
            <TextBlock x:Name="TxtStatus"
                       Text="" Foreground="{StaticResource FgSubtle}"
                       FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <!-- ── Sources list ─────────────────────────────────────────── -->
            <ItemsControl x:Name="SourcesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FgMain}"
                                               FontSize="13"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding TypeLabel}"
                                                   Foreground="{StaticResource FgSubtle}"
                                                   FontSize="11"/>
                                        <TextBlock Text=" · "
                                                   Foreground="{StaticResource FgSubtle}"
                                                   FontSize="11"/>
                                        <TextBlock Text="{Binding FolderOrReleases}"
                                                   Foreground="{StaticResource FgSubtle}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="Rescan"
                                            Style="{StaticResource Btn}"
                                            Padding="10,4" Margin="0,0,6,0"
                                            Tag="{Binding Id}"
                                            Click="BtnRescan_Click"/>
                                    <Button Content="Edit"
                                            Style="{StaticResource BtnAccent}"
                                            Padding="10,4" Margin="0,0,6,0"
                                            Tag="{Binding Id}"
                                            Click="BtnEditSource_Click"/>
                                    <Button Content="Remove"
                                            Style="{StaticResource BtnDanger}"
                                            Padding="10,4"
                                            Tag="{Binding Id}"
                                            Click="BtnRemoveSource_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Empty state ─────────────────────────────────────────── -->
            <Border x:Name="EmptyState"
                    Style="{StaticResource Card}"
                    Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" Margin="0,20">
                    <TextBlock Text="No sources added yet"
                               Foreground="{StaticResource FgSubtle}"
                               HorizontalAlignment="Center" FontSize="14"/>
                    <TextBlock Text="Click '+ Add Source' to add a GitHub repository."
                               Foreground="{StaticResource FgSubtle}"
                               HorizontalAlignment="Center"
                               FontSize="12" Margin="0,6,0,0"
                               TextWrapping="Wrap" MaxWidth="400"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
