<UserControl x:Class="PS5AutoPayloadTool.Views.SourcesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,20">

            <!-- ── Page Header ──────────────────────────────────────────── -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Payload Sources"
                           Style="{StaticResource PageTitle}"
                           VerticalAlignment="Center"
                           Margin="0"/>
                <Button Grid.Column="1"
                        x:Name="BtnToggleAdd"
                        Content="+ Add Source"
                        Style="{StaticResource BtnAccent}"
                        Click="BtnToggleAdd_Click"/>
            </Grid>

            <!-- ── Add Source Form (collapsed by default) ──────────────── -->
            <Border x:Name="AddForm"
                    Visibility="Collapsed"
                    Style="{StaticResource Card}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Add New Source" Style="{StaticResource SectionTitle}"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GitHub Owner"
                                       Foreground="{StaticResource FgSubtle}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtOwner"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Repository"
                                       Foreground="{StaticResource FgSubtle}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtRepo"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Source Type"
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbType"
                                  SelectionChanged="CmbType_SelectionChanged">
                            <ComboBoxItem Content="GitHub Releases" IsSelected="True"/>
                            <ComboBoxItem Content="GitHub Folder"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="File filter (e.g. *.elf)"
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtFilter"/>
                    </StackPanel>

                    <StackPanel x:Name="FolderPathPanel"
                                Visibility="Collapsed"
                                Margin="0,0,0,10">
                        <TextBlock Text="Folder path (for folder type)"
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtFolder"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="BtnScanAdd"
                                Content="Scan &amp; Add"
                                Style="{StaticResource BtnAccent}"
                                Margin="0,0,8,0"
                                Click="BtnScanAdd_Click"/>
                        <Button Content="Cancel"
                                Style="{StaticResource Btn}"
                                Click="BtnCancelAdd_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── Status line ─────────────────────────────────────────── -->
            <TextBlock x:Name="TxtStatus"
                       Text=""
                       Foreground="{StaticResource FgSubtle}"
                       FontSize="12"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"/>

            <!-- ── Sources list ─────────────────────────────────────────── -->
            <ItemsControl x:Name="SourcesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FgMain}"
                                               FontSize="13"/>
                                    <TextBlock Text="{Binding Type}"
                                               Foreground="{StaticResource FgSubtle}"
                                               FontSize="11" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding Filter}"
                                               Foreground="{StaticResource FgSubtle}"
                                               FontSize="11" Margin="0,1,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="Rescan"
                                            Style="{StaticResource Btn}"
                                            Margin="0,0,6,0" Padding="10,4"
                                            Tag="{Binding Id}"
                                            Click="BtnRescan_Click"/>
                                    <Button Content="Remove"
                                            Style="{StaticResource BtnDanger}"
                                            Padding="10,4"
                                            Tag="{Binding Id}"
                                            Click="BtnRemoveSource_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Empty state ─────────────────────────────────────────── -->
            <Border x:Name="EmptyState"
                    Style="{StaticResource Card}"
                    Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" Margin="0,20">
                    <TextBlock Text="No sources added yet"
                               Foreground="{StaticResource FgSubtle}"
                               HorizontalAlignment="Center"
                               FontSize="14"/>
                    <TextBlock Text="Click '+ Add Source' to add a GitHub repository as a payload source."
                               Foreground="{StaticResource FgSubtle}"
                               HorizontalAlignment="Center"
                               FontSize="12" Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               MaxWidth="400"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
