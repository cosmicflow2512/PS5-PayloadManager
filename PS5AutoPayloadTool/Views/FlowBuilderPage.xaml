<UserControl x:Class="PS5AutoPayloadTool.Views.FlowBuilderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PS5AutoPayloadTool.Views">

    <UserControl.Resources>
        <local:StringToBrushConverter x:Key="StringToBrush"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,10">

                <!-- ── Header: title + device ─────────────────────────── -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Autoload Builder"
                               Style="{StaticResource PageTitle}"
                               VerticalAlignment="Center"
                               Margin="0"/>

                    <!-- Autoload compatibility badge -->
                    <Border x:Name="CompatBadge"
                            Grid.Column="1"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Cursor="Help">
                        <Border.ToolTip>
                            <ToolTip MaxWidth="320">
                                <StackPanel>
                                    <TextBlock Text="Autoload TXT limitations:"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="• WAIT (port-based) steps are not supported"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="• LUA payloads are not supported"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="• Only ELF and BIN payloads are allowed"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="• Execution is strictly sequential (no port checks)"/>
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>
                        <TextBlock x:Name="TxtCompatBadge"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <Ellipse x:Name="EllipseLua"
                                 Width="8" Height="8"
                                 Fill="{StaticResource BgOverlay}"
                                 Margin="0,0,4,0"/>
                        <TextBlock x:Name="TxtLuaPortLabel"
                                   Text="Lua"
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="11" VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <Ellipse x:Name="EllipseElf"
                                 Width="8" Height="8"
                                 Fill="{StaticResource BgOverlay}"
                                 Margin="0,0,4,0"/>
                        <TextBlock x:Name="TxtElfPortLabel"
                                   Text="ELF"
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ComboBox Grid.Column="3"
                              x:Name="CmbDevice"
                              Width="200"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              SelectionChanged="CmbDevice_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Grid.Column="4"
                            Content="Check Ports"
                            Style="{StaticResource Btn}"
                            VerticalAlignment="Center"
                            Click="BtnCheckPorts_Click"/>
                </Grid>

                <!-- ── Step toolbar ───────────────────────────────────── -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="+ Payload"
                            Style="{StaticResource BtnAccent}"
                            Padding="12,5" Margin="0,0,6,0"
                            Click="BtnAddPayload_Click"/>
                    <Button Content="+ Wait"
                            Style="{StaticResource BtnYellow}"
                            Padding="12,5" Margin="0,0,6,0"
                            Click="BtnAddWait_Click"/>
                    <Button Content="+ Delay"
                            Style="{StaticResource BtnGreen}"
                            Padding="12,5"
                            Click="BtnAddDelay_Click"/>
                </StackPanel>

                <!-- ── Flow steps list ────────────────────────────────── -->
                <Border Style="{StaticResource Card}" Padding="10">
                    <StackPanel>
                        <TextBlock x:Name="TxtFlowEmpty"
                                   Text="No steps yet — click + Payload, + Wait or + Delay above."
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="12" Margin="4,4,4,0"
                                   Visibility="Visible"/>

                        <ItemsControl x:Name="FlowStepsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgBase}"
                                            BorderBrush="{StaticResource BgSurface}"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="8,6"
                                            Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Type badge -->
                                            <Border Grid.Column="0"
                                                    Background="#313244"
                                                    CornerRadius="3"
                                                    Padding="5,2"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding TypeLabel}"
                                                           Foreground="{Binding TypeColor, Converter={StaticResource StringToBrush}}"
                                                           FontSize="10" FontWeight="SemiBold"/>
                                            </Border>

                                            <!-- ── PAYLOAD ── -->
                                            <StackPanel x:Name="PayloadPanel"
                                                        Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0"
                                                        Visibility="Collapsed">
                                                <ComboBox ItemsSource="{Binding DataContext.PayloadNames,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          SelectedItem="{Binding Payload, Mode=TwoWay}"
                                                          Width="180" FontSize="12"
                                                          VerticalAlignment="Center"
                                                          SelectionChanged="CmbStepPayload_SelectionChanged"/>
                                                <ComboBox ItemsSource="{Binding VersionOptions}"
                                                          SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
                                                          Width="100" FontSize="11"
                                                          VerticalAlignment="Center"
                                                          Margin="4,0,0,0"
                                                          SelectionChanged="CmbStepVersion_SelectionChanged"/>
                                                <TextBlock Text=" → "
                                                           Foreground="{StaticResource FgSubtle}"
                                                           VerticalAlignment="Center" FontSize="12"
                                                           Margin="2,0"/>
                                                <TextBox Text="{Binding Port, Mode=TwoWay,
                                                             UpdateSourceTrigger=LostFocus}"
                                                         Width="68" MinWidth="68"
                                                         VerticalAlignment="Center"
                                                         FontFamily="Consolas"
                                                         LostFocus="StepField_LostFocus"/>
                                            </StackPanel>

                                            <!-- ── WAIT ── -->
                                            <StackPanel x:Name="WaitPanel"
                                                        Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0"
                                                        Visibility="Collapsed">
                                                <TextBlock Text="Port:"
                                                           Foreground="{StaticResource FgSubtle}"
                                                           VerticalAlignment="Center"
                                                           FontSize="12" Margin="0,0,6,0"/>
                                                <TextBox Text="{Binding Port, Mode=TwoWay,
                                                             UpdateSourceTrigger=LostFocus}"
                                                         Width="68" MinWidth="68"
                                                         FontFamily="Consolas"
                                                         LostFocus="StepField_LostFocus"/>
                                                <TextBlock Text="  Timeout:"
                                                           Foreground="{StaticResource FgSubtle}"
                                                           VerticalAlignment="Center"
                                                           FontSize="12" Margin="10,0,6,0"/>
                                                <TextBox Text="{Binding Timeout, Mode=TwoWay,
                                                             UpdateSourceTrigger=LostFocus}"
                                                         Width="58" MinWidth="58"
                                                         FontFamily="Consolas"
                                                         LostFocus="StepField_LostFocus"/>
                                                <TextBlock Text=" s"
                                                           Foreground="{StaticResource FgSubtle}"
                                                           VerticalAlignment="Center" FontSize="12"/>
                                            </StackPanel>

                                            <!-- ── DELAY ── -->
                                            <StackPanel x:Name="DelayPanel"
                                                        Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0"
                                                        Visibility="Collapsed">
                                                <TextBox Text="{Binding Ms, Mode=TwoWay,
                                                             UpdateSourceTrigger=LostFocus}"
                                                         Width="80" MinWidth="80"
                                                         FontFamily="Consolas"
                                                         LostFocus="StepField_LostFocus"/>
                                                <TextBlock Text=" ms"
                                                           Foreground="{StaticResource FgSubtle}"
                                                           VerticalAlignment="Center" FontSize="12"/>
                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="↑"
                                                        Style="{StaticResource Btn}"
                                                        Padding="5,2" Margin="0,0,2,0"
                                                        FontSize="10"
                                                        Tag="{Binding}"
                                                        Click="BtnMoveUp_Click"/>
                                                <Button Content="↓"
                                                        Style="{StaticResource Btn}"
                                                        Padding="5,2" Margin="0,0,2,0"
                                                        FontSize="10"
                                                        Tag="{Binding}"
                                                        Click="BtnMoveDown_Click"/>
                                                <Button Content="✕"
                                                        Style="{StaticResource BtnDanger}"
                                                        Padding="5,2"
                                                        FontSize="10"
                                                        Tag="{Binding}"
                                                        Click="BtnRemoveStep_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="payload">
                                            <Setter TargetName="PayloadPanel" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="wait_port">
                                            <Setter TargetName="WaitPanel" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="delay">
                                            <Setter TargetName="DelayPanel" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Bottom Control Bar ────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource BgMantle}"
                BorderBrush="{StaticResource BgSurface}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <StackPanel>

                <!-- Main actions -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Save as Profile"
                            Style="{StaticResource Btn}"
                            Margin="0,0,8,0"
                            Click="BtnSaveProfile_Click"/>
                    <Button Content="Export Autoload ZIP"
                            Style="{StaticResource BtnYellow}"
                            Margin="0,0,8,0"
                            Click="BtnExportZip_Click"/>
                    <Button x:Name="BtnRun"
                            Content="&#x25B6;  Run"
                            Style="{StaticResource BtnGreen}"
                            Margin="0,0,8,0"
                            Click="BtnRunFlow_Click"/>
                    <Button x:Name="BtnStop"
                            Content="&#x25A0;  Stop"
                            Style="{StaticResource BtnRed}"
                            IsEnabled="False"
                            Click="BtnStopFlow_Click"/>
                    <CheckBox x:Name="ChkSafeMode"
                              Content="Safe mode"
                              Foreground="{StaticResource FgSubtle}"
                              VerticalAlignment="Center"
                              Margin="12,0,0,0"
                              ToolTip="Run flow without sending payloads (dry run / test mode)"/>
                </StackPanel>

                <!-- Save name panel (hidden until "Save as Profile" clicked) -->
                <Border x:Name="SaveNamePanel"
                        Visibility="Collapsed"
                        Background="{StaticResource BgBase}"
                        BorderBrush="{StaticResource BgSurface}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="10,8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Enter a name for this profile:"
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="11" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSaveName"
                                     Grid.Column="0"
                                     FontSize="12"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Content="Save"
                                    Style="{StaticResource BtnAccent}"
                                    Padding="14,5" Margin="0,0,6,0"
                                    Click="BtnConfirmSave_Click"/>
                            <Button Grid.Column="2"
                                    Content="Cancel"
                                    Style="{StaticResource Btn}"
                                    Padding="10,5"
                                    Click="BtnCancelSave_Click"/>
                        </Grid>
                        <TextBlock x:Name="TxtSaveError"
                                   Foreground="{StaticResource Red}"
                                   FontSize="11" Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <ProgressBar x:Name="PrgFlow"
                             Minimum="0" Maximum="100" Value="0"
                             Margin="0,0,0,6"/>

                <Border Background="{StaticResource BgBase}"
                        BorderBrush="{StaticResource BgSurface}"
                        BorderThickness="1" CornerRadius="4"
                        Height="80">
                    <ScrollViewer x:Name="LogScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="8,5">
                        <TextBlock x:Name="TxtFlowLog"
                                   Text=""
                                   Foreground="{StaticResource FgSubtle}"
                                   FontSize="11" FontFamily="Consolas"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
