<UserControl x:Class="PS5AutoPayloadTool.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgPrimary}">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,16">
      <TextBlock Text="Logs" Foreground="{StaticResource TextPrimary}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Export" Style="{StaticResource BtnSecondary}" Click="OnExport" Margin="0,0,8,0"/>
        <Button Content="Clear"  Style="{StaticResource BtnSecondary}" Click="OnClear"/>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Background="{StaticResource BgCard}" CornerRadius="8">
      <ScrollViewer x:Name="Scroller" VerticalScrollBarVisibility="Auto" Padding="12">
        <ItemsControl x:Name="LogList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Text}" Foreground="{Binding Color}"
                         FontFamily="Consolas, Courier New" FontSize="12" Margin="0,1"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
