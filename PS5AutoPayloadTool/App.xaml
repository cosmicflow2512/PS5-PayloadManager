<Application x:Class="PS5AutoPayloadTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ── Colour Brushes ──────────────────────────────────────────────── -->
        <SolidColorBrush x:Key="BgBase"    Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgMantle"  Color="#181825"/>
        <SolidColorBrush x:Key="BgSurface" Color="#313244"/>
        <SolidColorBrush x:Key="BgOverlay" Color="#45475A"/>
        <SolidColorBrush x:Key="FgMain"    Color="#CDD6F4"/>
        <SolidColorBrush x:Key="FgSubtle"  Color="#6C7086"/>
        <SolidColorBrush x:Key="Accent"    Color="#89B4FA"/>
        <SolidColorBrush x:Key="Green"     Color="#A6E3A1"/>
        <SolidColorBrush x:Key="Red"       Color="#F38BA8"/>
        <SolidColorBrush x:Key="Yellow"    Color="#F9E2AF"/>
        <SolidColorBrush x:Key="Pink"      Color="#F5C2E7"/>

        <!-- ── Card Border ────────────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgMantle}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BgSurface}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="16"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>

        <!-- ── PageTitle TextBlock ────────────────────────────────────────── -->
        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="20"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Foreground"       Value="{StaticResource FgMain}"/>
            <Setter Property="Margin"           Value="0,0,0,16"/>
        </Style>

        <!-- ── SectionTitle TextBlock ────────────────────────────────────── -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontWeight"       Value="Medium"/>
            <Setter Property="Foreground"       Value="{StaticResource FgSubtle}"/>
            <Setter Property="Margin"           Value="0,0,0,8"/>
        </Style>

        <!-- ── Base Button ───────────────────────────────────────────────── -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource BgSurface}"/>
            <Setter Property="Foreground"       Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BgOverlay}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,6"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgOverlay}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Accent Button ─────────────────────────────────────────────── -->
        <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="#1C6BBE"/>
            <Setter Property="Foreground"  Value="#EFF1F5"/>
            <Setter Property="BorderBrush" Value="#89B4FA"/>
        </Style>

        <!-- ── Green Button ──────────────────────────────────────────────── -->
        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="#2D6A4A"/>
            <Setter Property="Foreground"  Value="{StaticResource Green}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Green}"/>
        </Style>

        <!-- ── Red Button ────────────────────────────────────────────────── -->
        <Style x:Key="BtnRed" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="#6B2D3A"/>
            <Setter Property="Foreground"  Value="{StaticResource Red}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Red}"/>
        </Style>

        <!-- ── Danger Button (transparent bg, red border) ────────────────── -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource Red}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Red}"/>
        </Style>

        <!-- ── Yellow Button ─────────────────────────────────────────────── -->
        <Style x:Key="BtnYellow" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background"  Value="#5C4C1E"/>
            <Setter Property="Foreground"  Value="{StaticResource Yellow}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Yellow}"/>
        </Style>

        <!-- ── TextBox ───────────────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="{StaticResource BgMantle}"/>
            <Setter Property="Foreground"               Value="{StaticResource FgMain}"/>
            <Setter Property="CaretBrush"               Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush"              Value="{StaticResource BgOverlay}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="8,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox ──────────────────────────────────────────────────── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource BgMantle}"/>
            <Setter Property="Foreground"      Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BgOverlay}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource BgMantle}"/>
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
            <Setter Property="Padding"    Value="8,4"/>
        </Style>

        <!-- ── ListBox ───────────────────────────────────────────────────── -->
        <Style TargetType="ListBox">
            <Setter Property="Background"      Value="{StaticResource BgMantle}"/>
            <Setter Property="Foreground"      Value="{StaticResource FgMain}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BgOverlay}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource FgMain}"/>
            <Setter Property="Padding"    Value="7,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground"                 Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#282838"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Slim ScrollBar ────────────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background"  Value="{StaticResource BgMantle}"/>
            <Setter Property="Foreground"  Value="{StaticResource BgOverlay}"/>
            <Setter Property="Width"       Value="6"/>
            <Setter Property="MinWidth"    Value="6"/>
        </Style>

        <!-- ── ProgressBar ───────────────────────────────────────────────── -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background"      Value="{StaticResource BgSurface}"/>
            <Setter Property="Foreground"      Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="6"/>
        </Style>

        <!-- ── Separator ─────────────────────────────────────────────────── -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BgSurface}"/>
        </Style>

    </Application.Resources>
</Application>
